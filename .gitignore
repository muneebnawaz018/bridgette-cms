node_modules
.next
# Alternate build dirs via NEXT_DIST_DIR — see distDir in next.config.mjs
.next-*
out
dist
coverage

# env
# Ignore every .env variant and allow the template back in, rather than listing suffixes.
# The old rules covered .env and .env*.local only, so .env.prod, .env.production and
# .env.staging would all have been committed with real credentials in them.
.env*
!.env.example

# misc
.DS_Store
*.pem
npm-debug.log*

# local secret scripts (never commit — hold API keys)
*.secret.sh

# typescript build info
*.tsbuildinfo
