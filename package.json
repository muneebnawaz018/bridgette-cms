{
  "name": "bridgette-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Bridgette Enterprises customer support portal and management system",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#.next\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/scripts/seed.ts",
    "sync-admin": "tsx src/scripts/sync-admin.ts",
    "check": "npm run typecheck && npm run lint && npm run lint:md && npm run format:check"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.4.0",
    "@mui/material-nextjs": "^6.4.0",
    "@mui/x-data-grid": "^7.23.6",
    "@scalar/nextjs-api-reference": "^0.11.9",
    "bcryptjs": "^2.4.3",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "next": "^15.1.6",
    "nodemailer": "^6.9.16",
    "notistack": "^3.0.2",
    "pino": "^10.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swr": "^2.4.2",
    "ua-parser-js": "^2.0.10",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "markdownlint-cli2": "^0.17.2",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
