# Copy to .env.local and fill in

# Database
MONGODB_URI=mongodb://localhost:27017/bridgette

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# JWT secrets (use long random strings, e.g. `openssl rand -base64 48`)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=7d

# SMTP (nodemailer) — cPanel/A2 mail. Port 465 + SMTP_SECURE=true is the combination that
# works; 587 and 25 are blocked outbound. SMTP_USER is the FULL mailbox address, and
# SMTP_FROM must use that same address or the server rejects the send (SPF/DMARC).
SMTP_HOST=mail.bridgetteenterprises.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=mailbox@bridgetteenterprises.com
SMTP_PASS=
SMTP_FROM=Bridgette Portal <mailbox@bridgetteenterprises.com>

# Super Admin seed (npm run seed) — only used when no Super Admin exists yet.
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=super.admin@bridgetteenterprises.com
SUPER_ADMIN_PASSWORD=change-me-strong-password

# --- Bot protection (optional) -------------------------------------------------
# Cloudflare Turnstile. Leave both blank to disable: the app then never asks for a
# challenge. When set, a challenge is demanded only after an account has failed to
# sign in repeatedly, so normal sign-ins are unaffected.
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-side cap on how long a single Mongo query may run, in milliseconds.
# Stops one pathological query from holding a pooled connection open. Default 10000.
MONGO_QUERY_TIMEOUT_MS=10000
