# Copy to .env.local and fill in

# Database
MONGODB_URI=mongodb://localhost:27017/bridgette

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# JWT secrets (use long random strings, e.g. `openssl rand -base64 48`)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=7d

# SMTP (nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Bridgette Portal <no-reply@bridgetteenterprises.com>

# Super Admin seed (npm run seed)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@bridgetteenterprises.com
SUPER_ADMIN_PASSWORD=change-me-strong-password
